# ----- Database -----
# Local dev: a plain SQLite file (the libsql adapter reads file: URLs).
# Production (Netlify / any serverless host): a hosted Turso database — set
# DATABASE_URL to the libsql:// URL and TURSO_AUTH_TOKEN to a Turso token.
# See DEPLOY-NETLIFY.md for the full walkthrough.
DATABASE_URL="file:./dev.db"
TURSO_AUTH_TOKEN=

# ----- AI: DeepSeek (OpenAI-compatible) -----
# Leave DEEPSEEK_API_KEY empty to use the built-in mock interpreter; set a real
# key to switch to live DeepSeek. NEVER commit the real key — for deployments,
# set it in the host's environment-variable settings, not in a file.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL="https://api.deepseek.com"
